default_platform(:ios)

APP_BUNDLE_ID = "com.chriscantu.SpeedReader"
EXTENSION_BUNDLE_ID = "com.chriscantu.SpeedReader.SpeedReaderExtension"
XCODE_PROJECT = "SpeedReader/SpeedReader.xcodeproj"
TARGET_NAMES = {
  APP_BUNDLE_ID => "SpeedReader",
  EXTENSION_BUNDLE_ID => "SpeedReaderExtension"
}.freeze

platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY"),
      is_key_content_base64: true
    )
  end

  # Fetch (or create) provisioning profiles via sigh.
  # sigh manages profiles only — it never creates certificates.
  # Certificate creation was the root cause of #55 and is prevented
  # by removing -allowProvisioningUpdates from xcodebuild args.
  private_lane :fetch_profiles do |options|
    profiles = {}
    [APP_BUNDLE_ID, EXTENSION_BUNDLE_ID].each do |bundle_id|
      get_provisioning_profile(
        app_identifier: bundle_id,
        platform: options[:platform]
      )
      profiles[bundle_id] = lane_context[SharedValues::SIGH_NAME]
    end
    profiles
  end

  # Switch Xcode project to manual signing with the given profiles.
  # Called once per platform build on the disposable CI checkout.
  private_lane :apply_signing do |options|
    profiles = options[:profiles]
    profiles.each do |bundle_id, profile_name|
      update_code_signing_settings(
        path: XCODE_PROJECT,
        use_automatic_signing: false,
        code_sign_identity: "Apple Distribution",
        profile_name: profile_name,
        targets: [TARGET_NAMES[bundle_id]]
      )
    end
  end

  desc "Build and upload to TestFlight (iOS + macOS)"
  lane :beta do
    # Keychain is created and certificates imported by the CI workflow.
    # Do NOT call setup_ci — it creates a second empty keychain that
    # becomes the default, hiding the installer certificate from
    # productbuild (which only searches the default keychain).

    # --- iOS ---
    ios_profiles = fetch_profiles(platform: "ios")
    apply_signing(profiles: ios_profiles)
    build_app(
      destination: "generic/platform=iOS",
      output_directory: "./build/ios",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: ios_profiles
      }
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)

    # --- macOS ---
    macos_profiles = fetch_profiles(platform: "macos")
    apply_signing(profiles: macos_profiles)
    build_mac_app(
      destination: "generic/platform=macOS",
      scheme: "SpeedReader",
      project: XCODE_PROJECT,
      output_directory: "./build/macos",
      export_method: "app-store",
      clean: true,
      installer_cert_name: "3rd Party Mac Developer Installer",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: macos_profiles
      }
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      pkg: lane_context[SharedValues::PKG_OUTPUT_PATH]
    )
  end

  desc "Delete an unsubmitted App Store version. Usage: fastlane delete_version version:1.2.4 platform:IOS"
  lane :delete_version do |options|
    require "jwt"
    require "base64"
    require "openssl"
    require "net/http"

    version_string = options[:version] or UI.user_error!("Pass version:X.Y.Z")
    platform = (options[:platform] || "IOS").upcase
    unless %w[IOS MAC_OS].include?(platform)
      UI.user_error!("platform must be IOS or MAC_OS")
    end

    app = Spaceship::ConnectAPI::App.find(APP_BUNDLE_ID)
    UI.user_error!("App #{APP_BUNDLE_ID} not found") unless app

    versions = app.get_app_store_versions(filter: {
      versionString: version_string,
      platform: platform
    })

    if versions.empty?
      UI.important("No #{platform} versions matching #{version_string} found.")
      next
    end

    # Build a JWT once for all delete requests
    private_key = OpenSSL::PKey::EC.new(Base64.decode64(ENV.fetch("APP_STORE_CONNECT_KEY")))
    jwt = JWT.encode(
      {
        iss: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
        exp: Time.now.to_i + 60 * 10,
        aud: "appstoreconnect-v1"
      },
      private_key,
      "ES256",
      { kid: ENV.fetch("APP_STORE_CONNECT_KEY_ID"), typ: "JWT" }
    )

    versions.each do |v|
      state = v.app_store_state
      unless state == "PREPARE_FOR_SUBMISSION"
        UI.important(
          "Skipping #{platform} #{v.version_string} — state is #{state}, " \
          "only PREPARE_FOR_SUBMISSION versions can be deleted via API."
        )
        next
      end

      UI.message("Deleting #{platform} #{v.version_string} (id: #{v.id}, state: #{state})")

      uri = URI("https://api.appstoreconnect.apple.com/v1/appStoreVersions/#{v.id}")
      request = Net::HTTP::Delete.new(uri)
      request["Authorization"] = "Bearer #{jwt}"
      response = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |http| http.request(request) }

      if response.code.to_i.between?(200, 299)
        UI.success("Deleted #{platform} #{v.version_string}")
      else
        UI.user_error!("Failed to delete: HTTP #{response.code} — #{response.body}")
      end
    end
  end

  desc "Build and upload to App Store (iOS + macOS)"
  lane :release do
    # Keychain is created and certificates imported by the CI workflow.
    # Do NOT call setup_ci — it creates a second empty keychain that
    # becomes the default, hiding the installer certificate from
    # productbuild (which only searches the default keychain).

    # --- iOS ---
    ios_profiles = fetch_profiles(platform: "ios")
    apply_signing(profiles: ios_profiles)
    build_app(
      destination: "generic/platform=iOS",
      output_directory: "./build/ios",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: ios_profiles
      }
    )
    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false
    )

    # --- macOS ---
    macos_profiles = fetch_profiles(platform: "macos")
    apply_signing(profiles: macos_profiles)

    # Archive the macOS build, then export manually so we can capture
    # the full xcodebuild -exportArchive output for diagnostics.
    # sh() runs from the repo root (fastlane cds up one level)
    repo_root = File.expand_path("..", __dir__)
    sh(
      "xcodebuild archive " \
      "-scheme SpeedReader " \
      "-project '#{File.join(repo_root, XCODE_PROJECT)}' " \
      "-destination 'generic/platform=macOS' " \
      "-archivePath '#{File.join(repo_root, "build/macos/SpeedReader.xcarchive")}' " \
      "clean"
    )

    archive_path = File.join(repo_root, "build/macos/SpeedReader.xcarchive")
    export_dir = File.join(repo_root, "build/macos/export")
    FileUtils.mkdir_p(export_dir)

    # Write the export options plist
    plist_path = File.join(repo_root, "build/macos/ExportOptions.plist")
    plist_content = <<~PLIST
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key>
        <string>app-store</string>
        <key>signingStyle</key>
        <string>manual</string>
        <key>installerSigningCertificate</key>
        <string>3rd Party Mac Developer Installer: Chris Cantu (4AKSB2RDBU)</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>#{APP_BUNDLE_ID}</key>
          <string>#{macos_profiles[APP_BUNDLE_ID]}</string>
          <key>#{EXTENSION_BUNDLE_ID}</key>
          <string>#{macos_profiles[EXTENSION_BUNDLE_ID]}</string>
        </dict>
      </dict>
      </plist>
    PLIST
    File.write(plist_path, plist_content)

    # Run export directly — capture stdout+stderr, don't abort on failure.
    sh(
      "xcodebuild -exportArchive " \
      "-archivePath '#{archive_path}' " \
      "-exportOptionsPlist '#{plist_path}' " \
      "-exportPath '#{export_dir}' " \
      "2>&1; true"
    )

    # List what was produced
    UI.important("=== Export directory contents ===")
    Dir.glob("#{export_dir}/**/*").each { |f| UI.important("  #{f}") }

    # Find the pkg
    pkg_path = Dir.glob("#{export_dir}/*.pkg").first
    UI.user_error!("macOS .pkg was not produced. See xcodebuild output above.") unless pkg_path

    upload_to_app_store(
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: true,
      precheck_include_in_app_purchases: false,
      pkg: pkg_path
    )
  end
end
